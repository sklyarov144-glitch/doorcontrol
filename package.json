{
  "name": "gross-lean-montage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "ci": "npm run lint -- --quiet && npm run check:scripts && npm run test && npm run build && npm audit --omit=dev",
    "verify:env": "node scripts/verify-env.mjs",
    "verify:deployment": "node scripts/verify-deployment-config.mjs",
    "auth:bootstrap": "node scripts/auth/bootstrap-creator.mjs",
    "auth:smoke": "node scripts/auth/role-smoke.mjs",
    "check:scripts": "node --check scripts/verify-deployment-config.mjs && node --check scripts/auth/bootstrap-creator.mjs && node --check scripts/auth/role-smoke.mjs && node --check scripts/backup/create-manifest.mjs && node --check scripts/backup/verify-manifest.mjs && node --check scripts/backup/create-restore-evidence.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "pilot:validate": "node scripts/pilot/validate-import.mjs",
    "pilot:import": "node scripts/pilot/import-supabase.mjs",
    "pilot:readiness": "node scripts/pilot/readiness-check.mjs",
    "load:smoke": "node scripts/pilot/load-smoke.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset"
  },
  "dependencies": {
    "@sentry/react": "^10.65.0",
    "@supabase/supabase-js": "^2.110.3",
    "lz-string": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "supabase": "^2.109.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
